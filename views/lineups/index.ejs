<% include ../partials/header %>

<div class="container">
  <div class="row">
    <div class="col-9">
      <div class="row">
        <div class="col-12">
          <h1>Lineups</h1>
        </div>
      </div>

      <div class="row">
        <div class="col-12">
          <p>
            <a href="/lineups/new">New Lineup</a>
          </p>

          <% lineups.forEach(lineup => { %>
            <div class="lineup">
              <a href="/lineups/<%= lineup._id %>"><%= lineup.teamName %></a>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <div id="navBar" class="col-3">
      <% include ../partials/navbar.ejs %>
    </div>
  </div>
</div>

<% include ../partials/footer %>
